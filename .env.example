# ── Liens Kiro : toutes ces variables sont OPTIONNELLES ──
# À configurer sur Vercel : Settings → Environment Variables.
# ⚠️ Préfixe VITE_ obligatoire. Les valeurs sont intégrées au BUILD :
#    après un changement sur Vercel, relancer un déploiement.

# Domaine officiel (canonical, Open Graph, liens d'aide par défaut)
VITE_SITE_URL=https://kirodating.com

# Centre d'aide (par défaut : {VITE_SITE_URL}/aide)
# VITE_HELP_BASE=https://kirodating.com/aide
# VITE_TERMS_URL=
# VITE_PRIVACY_URL=
# VITE_SUPPORT_URL=

# Contact
# VITE_CONTACT_EMAIL=contact@kirosocial.com
# VITE_SUPPORT_EMAIL=support@kirosocial.com

# Tester l'application
# VITE_TELEGRAM_URL=https://t.me/...
# VITE_WHATSAPP_URL=https://whatsapp.com/channel/...
# VITE_TESTFLIGHT_URL=https://testflight.apple.com/join/...
# VITE_TESTFLIGHT_STORE_URL=https://apps.apple.com/us/app/testflight/id899247664
# VITE_PLAYSTORE_URL=https://play.google.com/store/apps/details?id=...

# Réseaux sociaux
# VITE_TIKTOK_URL=https://www.tiktok.com/@kirosocial
# VITE_INSTAGRAM_URL=https://www.instagram.com/kirosocial
# VITE_FACEBOOK_URL=https://www.facebook.com/kirosocial
